# Cloudflare Pages Functions runtime variables.
# For local Pages development, copy these values into `.dev.vars`.
# For production, add the same keys in the Cloudflare Pages project settings.

PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
PAYPAL_PLAN_BOUTIQUE=P-...
PAYPAL_PLAN_PREMIER=P-...
PAYPAL_PLAN_CONCIERGE=P-...
DEMO_BOOKING_URL=https://calendar.app.google/your-booking-link
DEMO_INBOX_TO=ops@cayesdesk.com
N8N_DEMO_CALL_WEBHOOK_URL=https://n8n.example.com/webhook/cayesdesk-demo-call-follow-up
RESEND_API_KEY=re_...

# Optional. If omitted, the API falls back to `CayesDesk <onboarding@resend.dev>`.
RESEND_FROM_EMAIL=hello@cayesdesk.com

# ElevenLabs Post-Call Webhook
ELEVENLABS_WEBHOOK_SECRET=whsec_...
WEBHOOK_NOTIFICATION_EMAIL=admin@caytral.com

# Customer.io (server-side Track API)
CUSTOMERIO_SITE_ID=your_site_id
CUSTOMERIO_API_KEY=your_api_key

# Customer.io (client-side, exposed via Vite)
VITE_CUSTOMERIO_SITE_ID=your_site_id
