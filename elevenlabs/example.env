# Use these keys in .env.elevenlabs.local for ElevenLabs maintenance commands.
# Do not commit real secrets.

ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Set one of these identifiers.
ELEVENLABS_AGENT_ID=your-elevenlabs-agent-id
# ELEVENLABS_AGENT_NAME=CayesDesk Sales Agent

# Optional branch/versioning controls.
# ELEVENLABS_BRANCH_ID=your-elevenlabs-branch-id
# ELEVENLABS_ENABLE_VERSIONING=true

# Optional voice override. Omit to use the recommended CayesDesk female sales-concierge voice.
# ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id
